{
  "client": {
    "name": "eh-client-test",
    "engagement": "pilot"
  },
  "review": {
    "confidenceThreshold": 0.5,
    "severityThreshold": "low",
    "requireVerifierApproval": false
  },
  "agents": {
    "enabled": [
      "reviewer",
      "security",
      "domain-policy",
      "testing",
      "data-architecture",
      "sre-observability",
      "design-principles",
      "pr-intent-gap",
      "remediation"
    ]
  },
  "models": {
    "reviewer": "anthropic",
    "security": "anthropic",
    "domain-policy": "anthropic",
    "testing": "anthropic",
    "data-architecture": "anthropic",
    "sre-observability": "anthropic",
    "design-principles": "anthropic",
    "pr-intent-gap": "anthropic",
    "remediation": "anthropic"
  },
  "providers": {
    "anthropic": {}
  },
  "context": {
    "ignoredPaths": [
      "**/*.lock",
      "**/*.lockb",
      "**/.engagement-harness/**",
      "**/.next/**",
      "**/build/**",
      "**/coverage/**",
      "**/dist/**",
      "**/node_modules/**"
    ],
    "maxFiles": 30,
    "maxTokens": 80000
  },
  "ci": {
    "blockOnPolicy": false,
    "postComments": true,
    "artifactsOnly": false
  },
  "alm": {
    "platform": "github"
  },
  "feedback": {
    "enabled": true
  },
  "reports": {
    "formats": [
      "json",
      "markdown",
      "html"
    ],
    "outputDir": ".engagement-harness/reports"
  }
}
